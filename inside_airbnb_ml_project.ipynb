    "def final_static_preprocessing(df):\n",
    "    \"\"\"Realiza el preprocesamiento final de variables que no dependen de estadísticos con el objeto de evitar fuga de datos, de acuerdo a los hallazgos del EDA.\"\"\"\n",
    "    df = df.copy()\n",
    "    df['bathrooms_clipped'] = df['bathrooms'].fillna(1).replace(0, 1).clip(upper=4.0)\n",
    "    df['accommodates_clipped'] = df['accommodates'].clip(upper=8.0)\n",
    "\n",
    "    review_cols = [c for c in df.columns if c.startswith('review_scores_')]\n",
    "    for col in review_cols:\n",
    "        df[col] = df[col].fillna(0).clip(lower=4.0)\n",
    "\n",
    "    response_map = {'within an hour': 4, 'within a few hours': 3, 'within a day': 2, 'a few days or more': 1, 'Unknown': 0}\n",
    "    df['host_response_time_ordinal'] = df['host_response_time'].fillna('Unknown').map(response_map)\n",
    "\n",
    "    # Se conservan 'property_type', 'price', 'minimum_nights', 'reviews_per_month' para el Pipeline y el cálculo de la variable objetivo\n",
    "    cols_to_drop = [\n",
    "        'name', 'host_since', 'last_scraped', 'amenities', 'amenities_list',\n",
    "        'latitude', 'longitude', 'host_response_time', 'bathrooms',\n",
    "        'accommodates', 'first_review', 'last_review', 'number_of_reviews',\n",
    "        'neighbourhood_cleansed', 'host_longevity_years'\n",
    "    ]\n",
    "    df.drop(columns=cols_to_drop, errors='ignore', inplace=True)\n",
    "    return df"
   ]
