    "# Ejecutar la función de preporcesamiento final\n",
    "df_processed = final_static_preprocessing(df_base)\n",
    "\n",
    "# Hacer el split antes de calcular la variable objetivo\n",
    "df_train, df_hold = train_test_split(df_processed, test_size=0.2, random_state=42)\n",
