    "# Definición del espacio de búsqueda específico para LightGBM\n",
    "param_grid = {\n",
    "    'clf__n_estimators': [100, 200, 300],\n",
    "    'clf__max_depth': [5, 10, -1],          # -1 es sin límite\n",
    "    'clf__learning_rate': [0.01, 0.05, 0.1],\n",
    "    'clf__is_unbalance': [True, False],     # Alternativa a scale_pos_weight en LGBM\n",
    "    'clf__num_leaves': [31, 50]             # Parámetro clave en LGBM (controla complejidad)\n",
    "}\n",
    "\n",
    "# Creación del Pipeline con el ganador (MinMax)\n",
    "pipe_selected = Pipeline([\n",
    "    ('prep', get_model_preprocessor(MinMaxScaler())),\n",
    "    ('clf', LGBMClassifier(random_state=42, verbosity=-1))\n",
    "])\n",
    "\n",
    "# Configuración del GridSearch\n",
    "grid_selected = GridSearchCV(\n",
    "    pipe_selected,\n",
    "    param_grid,\n",
    "    cv=3,\n",
    "    scoring='recall', # Métrica objetivo para el negocio\n",
    "    verbose=1,\n",
    "    n_jobs=-1\n",
    ")\n",
    "\n",
    "# Entrenar\n",
    "grid_selected.fit(X_train, y_train)\n",
    "\n",
    "print(f\"Mejores parámetros: {grid_selected.best_params_}\")\n",
    "print(f\"Mejor Recall en CV: {grid_selected.best_score_:.4f}\")"
   ]
