   "source": [
    "# Preparar los datos transformados\n",
    "preprocesador = grid_selected.best_estimator_.named_steps['prep']\n",
    "features_finales = preprocesador.get_feature_names_out()\n",
    "# Limpiar los nombres (quitar el prefijo del transformer tipo 'numeric_standard_transform__')\n",
    "features_finales = [f.split('__')[-1] for f in features_finales]\n",
    "\n",
    "X_hold_transformado = preprocesador.transform(X_hold)\n",
    "X_hold_df = pd.DataFrame(X_hold_transformado, columns=features_finales)\n",
    "\n",
    "# Calcular SHAP\n",
    "modelo_final = grid_selected.best_estimator_.named_steps['clf']\n",
    "explainer = shap.TreeExplainer(modelo_final)\n",
    "shap_values = explainer.shap_values(X_hold_df)\n",
    "\n",
    "# Manejar salida de SHAP (porque LGBM devuelve lista para binario, tomamos el impacto en clase 1)\n",
    "shap_values_to_plot = shap_values[1] if isinstance(shap_values, list) else shap_values\n",
    "\n",
    "# --- VISUALIZACIÓN DEL SHAP SUMMARY PLOT ---\n",
    "plt.figure(figsize=(10, 7))\n",
    "shap.summary_plot(shap_values_to_plot, X_hold_df, plot_type=\"dot\", show=False)\n",
    "plt.title(\"Impacto de Variables Individuales (SHAP)\", fontsize=14, pad=20)\n",
    "plt.tight_layout()\n",
    "plt.show()\n",
    "\n",
    "# --- PROCESAMIENTO POR PILARES ESTRATÉGICOS ---\n",
    "\n",
    "# Definir función de mapeo\n",
    "def asignar_categoria(feat):\n",
    "    categorias_map = {\n",
    "        'host_acceptance_rate': 'Gestión',\n",
    "        'review_scores_value': 'Calidad Percibida',\n",
    "        'host_response_time_ordinal': 'Gestión',\n",
    "        'review_scores_checkin': 'Calidad Percibida',\n",
    "        'instant_bookable': 'Gestión',\n",
    "        'host_is_superhost': 'Gestión',\n",
    "        'review_scores_location': 'Calidad Percibida',\n",
    "        'review_scores_cleanliness': 'Calidad Percibida',\n",
    "        'calculated_host_listings_count': 'Gestión',\n",
    "        'review_scores_communication': 'Calidad Percibida',\n",
    "        'accommodates_clipped': 'Infraestructura y Perfil',\n",
    "        'host_response_rate': 'Gestión',\n",
    "        'price': 'Infraestructura y Perfil',\n",
    "        'review_scores_rating': 'Calidad Percibida',\n",
    "        'dist_obelisco': 'Geografía',\n",
    "        'review_scores_accuracy': 'Calidad Percibida',\n",
    "        'dist_palermo': 'Geografía',\n",
    "        'availability_365': 'Gestión',\n",
    "        'total_amenities_count': 'Infraestructura y Perfil',\n",
    "        'bathrooms_clipped': 'Infraestructura y Perfil',\n",
    "        'minimum_nights': 'Gestión'\n",
    "    }\n",
    "\n",
    "    if feat in categorias_map:\n",
    "        return categorias_map[feat]\n",
    "    # Si no está en el mapa, por descarte es Infraestructura (Property types y Amenities)\n",
    "    else:\n",
    "        return 'Infraestructura y Perfil'\n",
    "\n",
    "    # Determinar el impacto de las variables
    "    importancia_df = pd.DataFrame({
    "       'feature': X_hold_df.columns,
    "        'impacto': np.abs(shap_values_to_plot).mean(axis=0)
    "    })
    "\n",
    "importancia_df = importancia_df.sort_values(by='impacto', ascending=False)\n"
    "importancia_df['categoria'] = importancia_df['feature'].apply(asignar_categoria)\n",
    "\n",
    "# Agrupar,y obtener porcentajes\n",
    "importancia_por_categoria = importancia_df.groupby('categoria')['impacto'].sum()\n",
    "total_impacto = importancia_por_categoria.sum()\n",
    "porcentajes_categoria = (importancia_por_categoria / total_impacto * 100).sort_values(ascending=True)\n",
    "\n",
    "# Visualizar el impacto estratégico\n",
    "plt.figure(figsize=(11, 6))\n",
    "colors = plt.cm.Blues(np.linspace(0.6, 0.9, len(porcentajes_categoria)))\n",
    "ax = porcentajes_categoria.plot(kind='barh', color=colors, width=0.8)\n",
    "\n",
    "plt.title('Importancia de los Pilares Estratégicos (Impacto Agregado SHAP %)', fontsize=15, pad=15)\n",
    "plt.xlabel('Porcentaje de importancia en la predicción de éxito', fontsize=11)\n",
    "plt.ylabel('Dimensiones de Negocio', fontsize=11)\n",
    "\n",
    "# Incluir porcentajes dentro de las barras\n",
    "for i, v in enumerate(porcentajes_categoria):\n",
    "    if v > 0:\n",
    "        ax.text(v/2, i, f'{v:.1f}%',\n",
    "                va='center',\n",
    "                ha='center',\n",
    "                color='white',\n",
    "                fontweight='bold',\n",
    "                fontsize=12)\n",
    "\n",
    "ax.spines['top'].set_visible(False)\n",
    "ax.spines['right'].set_visible(False)\n",
    "plt.grid(axis='x', linestyle='--', alpha=0.3)\n",
    "plt.tight_layout()\n",
    "plt.show()"
   ]
