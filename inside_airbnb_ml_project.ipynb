    "# Configuración de parámetros y entrenamiento del modelo de Activo Puro\n",
    "best_params = {k.replace('clf__', ''): v for k, v in grid_selected.best_params_.items()}\n",
    "\n",
    "pipe_activo = Pipeline([\n",
    "    ('prep', get_preprocessor_activo_puro(MinMaxScaler())),\n",
    "    ('clf', LGBMClassifier(random_state=42, verbosity=-1, **best_params))\n",
    "])\n",
    "\n",
    "pipe_activo.fit(X_train, y_train)\n",
    "\n",
    "# Obtención de probabilidades y predicciones para ambos enfoques\n",
    "y_proba_integral = y_proba_tuned # Integral (H2) proviene del objeto grid_selected\n",
    "y_pred_integral = y_pred_tuned\n",
    "\n",
    "# Activo Puro (Enfoque H1)\n",
    "y_proba_activo = pipe_activo.predict_proba(X_hold)[:, 1]\n",
    "y_pred_activo = pipe_activo.predict(X_hold)\n",
    "\n",
    "# Preparar las curvas utilizando el set de Holdout\n",
    "fpr_act, tpr_act, _ = roc_curve(y_hold, y_proba_activo)\n",
    "fpr_int, tpr_int, _ = roc_curve(y_hold, y_proba_integral)\n",
    "\n",
    "# Calcular las métricas\n",
    "rec_act = recall_score(y_hold, y_pred_activo)\n",
    "rec_int = recall_score(y_hold, y_pred_integral)\n",
    "pre_act = precision_score(y_hold, y_pred_activo)\n",
    "pre_int = precision_score(y_hold, y_pred_integral)\n",
    "\n",
    "# Visualización\n",
    "plt.figure(figsize=(12, 8))\n",
    "\n",
    "# Curva Integral (Azul)\n",
    "plt.plot(fpr_int, tpr_int, color='#1f77b4', lw=3.5,\n",
    "         label=f'ENFOQUE H2: Integral (AUC: {auc(fpr_int, tpr_int):.2f})')\n",
    "\n",
    "# Curva Activo Puro (Rojo)\n",
    "plt.plot(fpr_act, tpr_act, color='#d62728', linestyle='--', lw=2,\n",
    "         label=f'ENFOQUE H1: Activo Puro (AUC: {auc(fpr_act, tpr_act):.2f})')\n",
    "\n",
    "# Línea base (Aleatoria)\n",
    "plt.plot([0, 1], [0, 1], color='gray', linestyle=':', alpha=0.5)\n",
    "\n",
    "# Cuadro de métricas comparativas\n",
    "texto_resumen = (\n",
    "    f\"Diferencial de Rendimiento:\\n\"\n",
    "    f\"• Incremento en Recall: +{(rec_int - rec_act)*100:.1f}% ({rec_int:.2f} vs {rec_act:.2f})\\n\"\n",
    "    f\"• Incremento en Precisión: +{(pre_int - pre_act)*100:.1f}% ({pre_int:.2f} vs {pre_act:.2f})\\n\"\n",
    "    f\"• Mejora en Separación (AUC): +{(auc(fpr_int, tpr_int) - auc(fpr_act, tpr_act))*100:.1f}%\"\n",
    ")\n",
    "\n",
    "plt.text(0.45, 0.2, texto_resumen, fontsize=12,\n",
    "         bbox=dict(facecolor='white', alpha=0.9, edgecolor='#1f77b4', boxstyle='round,pad=1'))\n",
    "\n",
    "# Ajuste de estética y graficado\n",
    "plt.title('Valor Agregado de la Gestión Operativa en Airbnb CABA', fontsize=16, fontweight='bold', pad=25)\n",
    "plt.xlabel('Tasa de Falsos Positivos (Riesgo de Inversión Fallida)', fontsize=12)\n",
    "plt.ylabel('Tasa de Verdaderos Positivos (Captura de Éxitos)', fontsize=12)\n",
    "plt.legend(loc='lower right', fontsize=11, frameon=True, shadow=True)\n",
    "plt.grid(alpha=0.15)\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.show()"
   ]
