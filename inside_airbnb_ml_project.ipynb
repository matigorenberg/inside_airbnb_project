    "# Transformador para limitar outliers (Clipping & Capping) basado en cuantiles\n",
    "class QuantileThresholdCapper(BaseEstimator, TransformerMixin):\n",
    "    def __init__(self, quantile=0.99):\n",
    "        self.quantile = quantile\n",
    "        self.thresholds_ = None\n",
    "        self.feature_names_in_ = None\n",
    "\n",
    "    def fit(self, X, y=None):\n",
    "        X_df = pd.DataFrame(X)\n",
    "        self.feature_names_in_ = X_df.columns.tolist()\n",
    "        self.thresholds_ = X_df.quantile(self.quantile)\n",
    "        return self\n",
    "\n",
    "    def transform(self, X):\n",
    "        X_df = pd.DataFrame(X).copy()\n",
    "        for col in X_df.columns:\n",
    "            if col in self.thresholds_:\n",
    "                X_df[col] = X_df[col].clip(upper=self.thresholds_[col])\n",
    "        return X_df.values\n",
    "\n",
    "    def get_feature_names_out(self, input_features=None):\n",
    "        return np.array(self.feature_names_in_)\n",
    "\n",
    "# Transformador logarítmico con mapeo de nombres\n",
    "log_transformer = FunctionTransformer(np.log1p, validate=False, feature_names_out='one-to-one')\n",
    "\n",
    "# Variables que requieren imputación y escalado estadístico\n",
    "features_to_impute = ['host_response_rate', 'host_acceptance_rate']\n",
    "\n",
    "# Variables categóricas\n",
    "categorical_features = ['property_type']\n",
    "\n",
    "# Variables relacionadas a reseñas\n",
    "review_cols = [c for c in X_train.columns if c.startswith('review_scores_')]\n",
    "\n",
    "# Variables numéricas que solo requieren escalado pero no transformación\n",
    "numeric_features = [\n",
    "    'availability_365', 'calculated_host_listings_count',\n",
    "    'bathrooms_clipped', 'accommodates_clipped', 'dist_obelisco', 'dist_palermo',\n",
    "    'total_amenities_count', 'host_response_time_ordinal'\n",
    "] + review_cols\n",
    "\n",
    "# Identificación automática de variables binarias/flags que pasan directo\n",
    "features_with_specific_transform = (\n",
    "    features_to_impute + categorical_features + numeric_features + ['price', 'minimum_nights']\n",
    ")\n",
    "binary_features_flags = [\n",
    "    col for col in X_train.columns if col not in features_with_specific_transform\n",
    "]\n",
    "\n",
    "\n",
    "def get_model_preprocessor(scaler_step):\n",
    "    \"\"\"\n",
    "    Construye el preprocesador permitiendo elegir el escalador (std o minmax).\n",
    "    Argumento scaler_step: Un objeto de escalado de sklearn (StandardScaler() o MinMaxScaler())\n",
    "    \"\"\"\n",
    "    return ColumnTransformer(\n",
    "        transformers=[\n",
    "            # Precio: Clipping -> Log -> Escalado\n",
    "            ('price_transform', Pipeline([\n",
    "                ('capper', QuantileThresholdCapper(quantile=0.99)),\n",
    "                ('log', log_transformer),\n",
    "                ('scaler', scaler_step)\n",
    "            ]), ['price']),\n",
    "\n",
    "            # Estancia Mínima: Capping -> Escalado\n",
    "            ('nights_transform', Pipeline([\n",
    "                ('capper', QuantileThresholdCapper(quantile=0.99)),\n",
    "                ('scaler', scaler_step)\n",
    "            ]), ['minimum_nights']),\n",
    "\n",
    "            # Imputación y Escalado\n",
    "            ('impute_transform', Pipeline([\n",
    "                ('imputer', SimpleImputer(strategy='mean')),\n",
    "                ('scaler', scaler_step)\n",
    "            ]), features_to_impute),\n",
    "\n",
    "            # Variables Categóricas\n",
    "            ('categorical_transform', OneHotEncoder(\n",
    "                min_frequency=30,\n",
    "                handle_unknown='infrequent_if_exist',\n",
    "                sparse_output=False\n",
    "            ), categorical_features),\n",
    "\n",
    "            # Escalado de Numéricas Estándar\n",
    "            ('numeric_standard_transform', scaler_step, numeric_features),\n",
    "\n",
    "            # Flags Binarias (Passthrough)\n",
    "            ('binary_flags_transform', 'passthrough', binary_features_flags)\n",
    "\n",
    "        ],\n",
    "        remainder='drop'\n",
    "    )"
   ]
  },
