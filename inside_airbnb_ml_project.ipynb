    "def run_strategic_eda(df):\n",
    "    \"\"\"\n",
    "    Genera el diagnóstico resumen para tópicos dales como geografía, capacidad,\n",
    "    precio, y relevancia de amenities, entre otros.\n",
    "    \"\"\"\n",
    "    sns.set_theme(style=\"whitegrid\")\n",
    "    df_eda = df.copy()\n",
    "\n",
    "    # --- TARGET TEMPORAL PARA DIAGNÓSTICO ---\n",
    "    target = 'success_target'\n",
    "    if target not in df_eda.columns:\n",
    "        q75 = df_eda['reviews_per_month'].quantile(0.75)\n",
    "        df_eda[target] = (df_eda['reviews_per_month'] > q75).astype(int)\n",
    "\n",
    "    # --- MATRIZ DE CORRELACIONES (Spearman) ---\n",
    "    df_num = df_eda.select_dtypes(include=[np.number]).drop(columns=['id', target], errors='ignore').copy()\n",
    "    cols_to_drop = [c for c in df_num.columns if c.startswith('amenity_') or c.startswith('is_')]\n",
    "    df_num.drop(columns=cols_to_drop, inplace=True, errors='ignore')\n",
    "\n",
    "    if df_num.shape[1] >= 2:\n",
    "        corr = df_num.corr(method='spearman')\n",
    "        mask = (np.abs(corr) < 0.55) | np.eye(corr.shape[0], dtype=bool)\n",
    "        plt.figure(figsize=(14, 10))\n",
    "        sns.heatmap(corr, mask=mask, annot=True, fmt=\".2f\", cmap='coolwarm', center=0, linewidths=.5, annot_kws={\"size\": 8}, square=True, cbar_kws={\"shrink\": .8})\n",
    "        plt.title(\"Matriz de Correlaciones: Variables Redundantes (Spearman > 0.55)\", fontsize=15)\n",
    "        plt.xticks(rotation=45, ha='right')\n",
    "        plt.show()\n",
    "\n",
    "    # --- GEOGRAFÍA DEL ÉXITO ---\n",
    "    heat_data = df_eda[df_eda[target] == 1][['latitude', 'longitude']].dropna().values.tolist()\n",
    "    m = folium.Map(location=[-34.6037, -58.3816], zoom_start=12)\n",
    "    if heat_data:\n",
    "        HeatMap(heat_data, radius=12, blur=15).add_to(m)\n",
    "    display(m)\n",
    "\n",
    "    # --- IMPACTO DE INFRAESTRUCTURA ---\n",
    "    fig, ax = plt.subplots(1, 2, figsize=(16, 5))\n",
    "    # Capacidad\n",
    "    sns.barplot(data=df_eda, x='accommodates', y=target, ax=ax[0], palette='magma', hue='accommodates', dodge=False, estimator=np.mean)\n",
    "    ax[0].axhline(df_eda[target].mean(), color='red', linestyle='--', label='Promedio Éxito')\n",
    "    ax[0].set_title('Probabilidad de Éxito por Capacidad')\n",
    "    # Baños\n",
    "    sns.barplot(data=df_eda, x='bathrooms', y=target, ax=ax[1], palette='viridis', hue='bathrooms', dodge=False, estimator=np.mean)\n",
    "    ax[1].axhline(df_eda[target].mean(), color='red', linestyle='--')\n",
    "    ax[1].set_title('Probabilidad de Éxito por Baños')\n",
    "    ax[1].tick_params(axis='x', rotation=45)\n",
    "    plt.show()\n",
    "\n",
    "    # --- JUSTIFICACIÓN TRANSFORMACIÓN DE PRECIO ---\n",
    "    fig, ax = plt.subplots(1, 2, figsize=(16, 5))\n",
    "    p99_price = df_eda['price'].quantile(0.99)\n",
    "    sns.histplot(df_eda['price'].clip(upper=p99_price), kde=True, color='#d62728', ax=ax[0])\n",
    "    ax[0].set_title(f'Distribución Original (p99={p99_price:.0f})\\nSkew: {df_eda[\"price\"].skew():.2f}')\n",
    "    sns.histplot(np.log1p(df_eda['price']), kde=True, color='teal', ax=ax[1])\n",
    "    ax[1].set_title(f'Distribución Log (Transformada)\\nSkew: {np.log1p(df_eda[\"price\"]).skew():.2f}')\n",
    "    plt.tight_layout()\n",
    "    plt.show()\n",
    "\n",
    "    # --- JUSTIFICACIÓN CAPPING DE NOCHES MÍNIMAS ---\n",
    "    fig, ax = plt.subplots(1, 2, figsize=(16, 5))\n",
    "\n",
    "    # Antes: Distribución Original\n",
    "    orig_nights = pd.to_numeric(df_eda['minimum_nights'], errors='coerce').dropna()\n",
    "    sns.histplot(orig_nights[orig_nights <= 100], bins=30, kde=False, color='#d62728', ax=ax[0])\n",
    "    ax[0].set_title(f'Distribución Original (Recortada a 100 para vista)\\nSkew: {orig_nights.skew():.2f}')\n",
    "    ax[0].set_xlabel('Noches Mínimas')\n",
    "\n",
    "    # Después: Countplot con el Capping al p99 (tu código inspirado)\n",
    "    p99_nights = df_eda['minimum_nights'].quantile(0.99)\n",
    "    # Aplicamos el capping para la visualización\n",
    "    data_plot = df_eda['minimum_nights'].clip(upper=p99_nights)\n",
    "\n",
    "    sns.countplot(x=data_plot.astype(int), color='steelblue', ax=ax[1])\n",
    "    # Ajustamos los ticks para que no se amontonen si el p99 es alto\n",
    "    if p99_nights > 20:\n",
    "        for ind, label in enumerate(ax[1].get_xticklabels()):\n",
    "            if ind % 5 != 0: label.set_visible(False)\n",
    "\n",
    "    ax[1].set_title(f'Distribución con Capping (p99={p99_nights:.0f})\\nSkew: {data_plot.skew():.2f}')\n",
    "    ax[1].set_xlabel('Noches Mínimas (Capped)')\n",
    "    ax[1].set_ylabel('Cantidad de Propiedades')\n",
    "\n",
    "    plt.tight_layout()\n",
    "    plt.show()\n",
    "\n",
    "    # --- ANÁLISIS DE REVIEWS (Distribuciones Reales) ---\n",
    "    review_cols = [c for c in df_eda.columns if c.startswith('review_scores_')]\n",
    "    if review_cols:\n",
    "        n = len(review_cols)\n",
    "        ncols = 2\n",
    "        nrows = (n + ncols - 1) // ncols\n",
    "        plt.figure(figsize=(12, 3.5 * nrows))\n",
    "        for i, col in enumerate(review_cols, 1):\n",
    "            plt.subplot(nrows, ncols, i)\n",
    "            data_real = df_eda[col].replace(0, np.nan).dropna() # Solo valores reales\n",
    "            sns.histplot(data_real, bins=20, kde=True, color='skyblue')\n",
    "            plt.title(f'Distribución real: {col}')\n",
    "        plt.tight_layout()\n",
    "        plt.show()\n",
    "\n",
    "    # --- IMPACTO DE AMENITIES (Ranking y Volumen) ---\n",
    "    # Procesar amenities\n",
    "    if 'amenities' in df_eda.columns:\n",
    "        df_eda['amenities_list'] = df_eda['amenities'].apply(lambda x: ast.literal_eval(x) if isinstance(x, str) else [])\n",
    "        all_am = df_eda['amenities_list'].explode()\n",
    "        top_20 = [item for item, count in Counter(all_am).most_common(20)]\n",
    "\n",
    "        # Gráfico de Impacto Individual\n",
    "        impacts = {am: (df_eda[df_eda['amenities_list'].apply(lambda x: am in x)][target].mean() -\n",
    "                        df_eda[df_eda['amenities_list'].apply(lambda x: am not in x)][target].mean()) * 100\n",
    "                   for am in top_20}\n",
    "        df_impacto = pd.DataFrame.from_dict(impacts, orient='index', columns=['Diff']).sort_values('Diff')\n",
    "\n",
    "        plt.figure(figsize=(10, 8))\n",
    "        df_impacto['Diff'].plot(kind='barh', color=['#1f77b4' if x > 0 else '#d62728' for x in df_impacto['Diff']])\n",
    "        plt.title(\"Ranking: Impacto de Amenities en el Éxito (%)\")\n",
    "        plt.axvline(0, color='black', lw=1)\n",
    "        plt.show()\n",
    "\n",
    "        # Gráfico de Volumen (Bins)\n",
    "        df_eda['total_amenities_count'] = df_eda['amenities_list'].apply(len)\n",
    "        df_eda['amenity_count_bins'] = pd.cut(df_eda['total_amenities_count'], bins=[0, 10, 20, 30, 40, 50, 100], right=False)\n",
    "        plt.figure(figsize=(10, 6))\n",
    "        sns.barplot(data=df_eda, x='amenity_count_bins', y=target, palette='viridis', estimator=np.mean)\n",
    "        plt.axhline(df_eda[target].mean(), color='red', linestyle='--')\n",
    "        plt.title(\"Impacto del Volumen de Amenities\")\n",
    "        plt.xticks(rotation=45)\n",
    "        plt.show()\n",
    "\n",
    "    # --- TABLA RESUMEN DE OUTLIERS Y CLIPPING (COMPLETA) ---\n",
    "    rows = []\n",
    "    df_enriched = df.copy()\n",
    "\n",
    "    # Capping percentil 99 para Price y Minimum Nights\n",
    "    for col in ['price', 'minimum_nights']:\n",
    "        if col in df_eda.columns:\n",
    "            orig = pd.to_numeric(df_eda[col], errors='coerce')\n",
    "            thresh = orig.quantile(0.99)\n",
    "            processed = orig.clip(upper=thresh)\n",
    "\n",
    "            rows.append({\n",
    "                'variable': col,\n",
    "                'operation': 'capping_p99',\n",
    "                'threshold': thresh,\n",
    "                'n_nonnull': int(orig.notna().sum()),\n",
    "                'n_clipped': int((orig > thresh).sum()),\n",
    "                'pct_clipped': (orig > thresh).sum() / len(orig) * 100,\n",
    "                'skew_before': orig.skew(),\n",
    "                'skew_after': processed.skew()\n",
    "            })\n",
    "\n",
    "    # Clipping fijo para Accommodates y Bathrooms\n",
    "    clips_fijos = {'accommodates': 8.0, 'bathrooms': 4.0}\n",
    "    for col, thresh in clips_fijos.items():\n",
    "        if col in df_eda.columns:\n",
    "            orig = pd.to_numeric(df_eda[col], errors='coerce')\n",
    "            processed = orig.clip(upper=thresh)\n",
    "\n",
    "            rows.append({\n",
    "                'variable': col,\n",
    "                'operation': 'clipping_fixed',\n",
    "                'threshold': thresh,\n",
    "                'n_nonnull': int(orig.notna().sum()),\n",
    "                'n_clipped': int((orig > thresh).sum()),\n",
    "                'pct_clipped': (orig > thresh).sum() / len(orig) * 100,\n",
    "                'skew_before': orig.skew(),\n",
    "                'skew_after': processed.skew()\n",
    "            })\n",
    "\n",
    "    # Lower Clipping para Reviews (Imputando 0 primero)\n",
    "    review_cols = [\n",
    "        'review_scores_value', 'review_scores_cleanliness', 'review_scores_checkin',\n",
    "        'review_scores_location', 'review_scores_communication', 'review_scores_rating',\n",
    "        'review_scores_accuracy'\n",
    "    ]\n",
    "    for col in review_cols:\n",
    "        if col in df_eda.columns:\n",
    "            orig = pd.to_numeric(df_eda[col], errors='coerce')\n",
    "            imputed = orig.fillna(0)\n",
    "            processed = imputed.clip(lower=4.0)\n",
    "\n",
    "            # Para el skew_after de reviews, se ignoran los 0 imputados\n",
    "            skew_after_val = processed[processed > 0].skew()\n",
    "\n",
    "            rows.append({\n",
    "                'variable': col,\n",
    "                'operation': 'clipping_lower',\n",
    "                'threshold': 4.0,\n",
    "                'n_nonnull': int(orig.notna().sum()),\n",
    "                'n_clipped': int((imputed < 4.0).sum()),\n",
    "                'pct_clipped': (imputed < 4.0).sum() / len(imputed) * 100,\n",
    "                'skew_before': orig.skew(),\n",
    "                'skew_after': skew_after_val\n",
    "            })\n",
    "\n",
    "    summary_table = pd.DataFrame(rows).round(3)\n",
    "    cols_order = ['variable', 'operation', 'threshold', 'n_nonnull', 'n_clipped', 'pct_clipped', 'skew_before', 'skew_after']\n",
    "    summary_table = summary_table[cols_order]\n",
    "\n",
    "    print(\"Resumen de Auditoría de Datos (Capping & Clipping):\")\n",
    "    display(summary_table)\n",
    "\n",
    "\n",
    "# Ejecución del EDA (Fuera del pipeline)\n",
    "eda_summary = run_strategic_eda(df_base.copy())"
   ]
