    "y_hold = (df_hold['reviews_per_month'] > q75_train).astype(int)\n",
    "\n",
    "# Eliminar la variable original para evitar fuga de datos\n",
    "X_train = df_train.drop(columns=['reviews_per_month'])\n",
    "X_hold = df_hold.drop(columns=['reviews_per_month'])"
