   "source": [
    "def get_preprocessor_activo_puro(scaler_step):\n",
    "    \"\"\"\n",
    "    Construye el preprocesador para el modelo de Activo Puro (Enfoque H1).\n",
    "    Argumento scaler_step: Un objeto de escalado de sklearn (StandardScaler() o MinMaxScaler())\n",
    "    \"\"\"\n",
    "    return ColumnTransformer(\n",
    "        transformers=[\n",
    "            ('price_transform', Pipeline([\n",
    "                ('capper', QuantileThresholdCapper(quantile=0.99)),\n",
    "                ('log', log_transformer),\n",
    "                ('scaler', scaler_step)\n",
    "            ]), ['price']),\n",
    "\n",
    "            ('nights_transform', Pipeline([\n",
    "                ('capper', QuantileThresholdCapper(quantile=0.99)),\n",
    "                ('scaler', scaler_step)\n",
    "            ]), ['minimum_nights']),\n",
    "\n",
    "            ('categorical_transform', OneHotEncoder(\n",
    "                min_frequency=30, handle_unknown='infrequent_if_exist', sparse_output=False\n",
    "            ), ['property_type']),\n",
    "\n",
    "            ('numeric_standard', scaler_step, [\n",
    "                'bathrooms_clipped', 'accommodates_clipped', 'dist_obelisco',\n",
    "                'dist_palermo', 'total_amenities_count'\n",
    "            ]),\n",
    "\n",
    "            ('amenities_flags', 'passthrough', amenities_cols)\n",
    "        ],\n",
    "        remainder='drop'\n",
    "    )"
   ]
  },
