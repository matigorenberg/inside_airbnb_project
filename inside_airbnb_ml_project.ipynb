   "source": [
    "# Definición de los modelos base\n",
    "base_models = {\n",
    "    'LogReg': LogisticRegression(max_iter=2000),\n",
    "    'RF': RandomForestClassifier(random_state=42),\n",
    "    'XGB': XGBClassifier(random_state=42),\n",
    "    'LGBM': LGBMClassifier(random_state=42, verbosity=-1)\n",
    "}\n",
    "\n",
    "# Definición de los escaladores\n",
    "scalers = {'Std': StandardScaler(), 'MinMax': MinMaxScaler()}\n",
    "\n",
    "results = []\n",
    "trained_pipes = {}\n",
    "cv = StratifiedKFold(n_splits=3, shuffle=True, random_state=42)\n",
    "\n",
    "# Loop de experimentación\n",
    "for model_name, model in base_models.items():\n",
    "    for scaler_name, scaler in scalers.items():\n",
    "\n",
    "        full_name = f\"{model_name}_{scaler_name}\"\n",
    "\n",
    "        # Construcción del Pipeline\n",
    "        pipe = Pipeline([\n",
    "            ('prep', get_model_preprocessor(scaler)),\n",
    "            ('clf', model)\n",
    "        ])\n",
    "\n",
    "        start_time = time.time()\n",
    "\n",
    "        # Cross-validation\n",
    "        cv_results = cross_validate(pipe, X_train, y_train, cv=cv,\n",
    "                                    scoring=['recall', 'roc_auc', 'f1'])\n",
    "\n",
    "        # Fit final en Train para evaluación en Holdout\n",
    "        pipe.fit(X_train, y_train)\n",
    "\n",
    "        # Guardado del modelo entrenado\n",
    "        trained_pipes[full_name] = pipe\n",
    "\n",
    "        # Cálculo del tiempo de entrenamiento\n",
    "        tiempo_total = time.time() - start_time\n",
    "\n",
    "        # Predicciones\n",
    "        y_pred = pipe.predict(X_hold)\n",
    "        y_proba = pipe.predict_proba(X_hold)[:, 1]\n",
    "\n",
    "        results.append({\n",
    "            'Modelo': full_name,\n",
    "            'Recall_CV': cv_results['test_recall'].mean(),\n",
    "            'ROC-AUC_CV': cv_results['test_roc_auc'].mean(),\n",
    "            'F1_CV': cv_results['test_f1'].mean(),\n",
    "            'Recall_Holdout': recall_score(y_hold, y_pred),\n",
    "            'ROC-AUC_Holdout': roc_auc_score(y_hold, y_proba),\n",
    "            'Tiempo_Seg': round(tiempo_total, 2)\n",
    "        })\n",
    "\n",
    "# DataFrame de métricas\n",
    "metrics_df = pd.DataFrame(results).sort_values('ROC-AUC_Holdout', ascending=False)\n",
    "display(metrics_df)"
   ]
  },
